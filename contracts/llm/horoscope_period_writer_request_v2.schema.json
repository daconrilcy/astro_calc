{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_period_writer_request_v2",
  "type": "object",
  "required": [
    "contract_version",
    "service_code",
    "generation_mode",
    "target_language_code",
    "period_resolution",
    "scan_plan",
    "detail_profile_code",
    "semantic_brief",
    "evidence",
    "safety_profile",
    "astrologer_persona",
    "output_contract_version"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "const": "horoscope_period_writer_request_v2" },
    "service_code": { "const": "horoscope_premium_next_7_days_natal" },
    "generation_mode": { "const": "semantic_brief_v2" },
    "target_language_code": { "enum": ["fr", "en", "es", "de"] },
    "astrologer_persona": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "persona_id": { "type": "string", "maxLength": 120 },
        "tone": { "$ref": "#/definitions/persona_terms_8" },
        "lexical_field": { "$ref": "#/definitions/persona_terms_20" },
        "priority_domains": { "$ref": "#/definitions/persona_terms_12" },
        "avoid_style": { "$ref": "#/definitions/persona_terms_20" },
        "interpretation_style": { "type": "string", "maxLength": 240 }
      }
    },
    "period_resolution": {
      "type": "object",
      "required": ["anchor_date", "timezone", "included_dates"],
      "additionalProperties": true,
      "properties": {
        "anchor_date": { "$ref": "#/definitions/date" },
        "timezone": { "type": "string" },
        "included_dates": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/date" }
        }
      }
    },
    "scan_plan": {
      "type": "object",
      "required": ["snapshots"],
      "additionalProperties": true,
      "properties": {
        "snapshots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["snapshot_key"],
            "properties": {
              "snapshot_key": { "$ref": "#/definitions/snapshot_key" }
            }
          }
        }
      }
    },
    "detail_profile_code": { "const": "premium_rich" },
    "semantic_brief": {
      "type": "object",
      "required": [
        "editorial_arc",
        "editorial_angles",
        "section_roles",
        "period_arc_keywords",
        "dominant_keywords",
        "week_tone_codes",
        "week_intensity",
        "daily_signal_summary",
        "best_day_candidates",
        "watch_day_candidates",
        "key_day_candidates",
        "window_candidates",
        "domain_candidates",
        "repeating_arcs"
      ],
      "additionalProperties": false,
      "properties": {
        "editorial_arc": { "$ref": "#/definitions/editorial_arc" },
        "editorial_angles": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": { "$ref": "#/definitions/editorial_angle" }
        },
        "section_roles": { "$ref": "#/definitions/section_roles" },
        "period_arc_keywords": { "$ref": "#/definitions/short_keyword_array" },
        "dominant_keywords": { "$ref": "#/definitions/short_keyword_array" },
        "week_tone_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "maxLength": 64 }
        },
        "week_intensity": { "$ref": "#/definitions/intensity" },
        "daily_signal_summary": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": { "$ref": "#/definitions/daily_signal_summary" }
        },
        "best_day_candidates": { "type": "array", "items": { "$ref": "#/definitions/day_candidate" } },
        "watch_day_candidates": { "type": "array", "items": { "$ref": "#/definitions/day_candidate" } },
        "key_day_candidates": { "type": "array", "items": { "$ref": "#/definitions/day_candidate" } },
        "window_candidates": { "type": "array", "items": { "$ref": "#/definitions/window_candidate" } },
        "domain_candidates": { "type": "array", "items": { "$ref": "#/definitions/domain_candidate" } },
        "repeating_arcs": { "type": "array", "items": { "$ref": "#/definitions/repeating_arc" } }
      }
    },
    "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/evidence" } },
    "safety_profile": {
      "type": "object",
      "required": [
        "domain",
        "forbid_medical_guidance",
        "forbid_fatalism",
        "forbid_financial_promises",
        "forbid_certain_predictions",
        "persona_cannot_override_safety",
        "evidence_keys_must_come_from_request"
      ],
      "additionalProperties": false,
      "properties": {
        "domain": { "const": "astrology_public_guidance" },
        "forbid_medical_guidance": { "const": true },
        "forbid_fatalism": { "const": true },
        "forbid_financial_promises": { "const": true },
        "forbid_certain_predictions": { "const": true },
        "persona_cannot_override_safety": { "const": true },
        "evidence_keys_must_come_from_request": { "const": true }
      }
    },
    "output_contract_version": { "const": "horoscope_period_response_v1" }
  },
  "definitions": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "snapshot_key": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}:\\d{2}:\\d{2}$" },
    "score": { "type": "number", "minimum": 0, "maximum": 1 },
    "intensity": { "enum": ["low", "medium", "high"] },
    "short_keyword": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "not": { "pattern": "[.!?:;\\n\\r]" }
    },
    "short_keyword_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/short_keyword" }
    },
    "evidence_keys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "source_snapshot_keys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/snapshot_key" }
    },
    "persona_term": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "not": { "pattern": "(?i)(ignore|system|developer|prompt|schema|bypass|override|jailbreak)" }
    },
    "persona_terms_8": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/persona_term" }
    },
    "persona_terms_12": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/persona_term" }
    },
    "persona_terms_20": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/persona_term" }
    },
    "brief_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "editorial_arc": {
      "type": "object",
      "required": ["purpose", "days"],
      "additionalProperties": false,
      "properties": {
        "purpose": { "$ref": "#/definitions/brief_text" },
        "days": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "type": "object",
            "required": ["date", "phase", "editorial_function"],
            "additionalProperties": false,
            "properties": {
              "date": { "$ref": "#/definitions/date" },
              "phase": { "type": "string", "maxLength": 64 },
              "editorial_function": { "$ref": "#/definitions/brief_text" }
            }
          }
        }
      }
    },
    "editorial_angle": {
      "type": "object",
      "required": ["date", "angle_code", "angle_hint", "avoid_repetition_hint"],
      "additionalProperties": false,
      "properties": {
        "date": { "$ref": "#/definitions/date" },
        "angle_code": { "type": "string", "maxLength": 64 },
        "angle_hint": { "$ref": "#/definitions/brief_text" },
        "avoid_repetition_hint": { "$ref": "#/definitions/brief_text" }
      }
    },
    "section_roles": {
      "type": "object",
      "required": [
        "overview_role",
        "timeline_role",
        "domains_role",
        "best_window_role",
        "watch_window_role",
        "strategy_role"
      ],
      "additionalProperties": false,
      "properties": {
        "overview_role": { "$ref": "#/definitions/brief_text" },
        "timeline_role": { "$ref": "#/definitions/brief_text" },
        "domains_role": { "$ref": "#/definitions/brief_text" },
        "best_window_role": { "$ref": "#/definitions/brief_text" },
        "watch_window_role": { "$ref": "#/definitions/brief_text" },
        "strategy_role": { "$ref": "#/definitions/brief_text" }
      }
    },
    "daily_signal_summary": {
      "type": "object",
      "required": [
        "date",
        "day_index",
        "main_event_keys",
        "evidence_keys",
        "theme_codes",
        "tone_codes",
        "intensity",
        "keywords",
        "opportunity_keywords",
        "risk_keywords",
        "avoid_keywords"
      ],
      "additionalProperties": false,
      "properties": {
        "date": { "$ref": "#/definitions/date" },
        "day_index": { "type": "integer" },
        "main_event_keys": { "type": "array", "uniqueItems": true, "items": { "type": "string", "maxLength": 120 } },
        "evidence_keys": { "$ref": "#/definitions/evidence_keys" },
        "theme_codes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "maxLength": 64 } },
        "tone_codes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "maxLength": 64 } },
        "intensity": { "$ref": "#/definitions/intensity" },
        "role_hint": { "type": ["string", "null"] },
        "keywords": { "$ref": "#/definitions/short_keyword_array" },
        "opportunity_keywords": { "$ref": "#/definitions/short_keyword_array" },
        "risk_keywords": { "$ref": "#/definitions/short_keyword_array" },
        "avoid_keywords": { "$ref": "#/definitions/short_keyword_array" }
      }
    },
    "day_candidate": {
      "type": "object",
      "required": ["date", "candidate_type", "score", "keywords", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "date": { "$ref": "#/definitions/date" },
        "candidate_type": { "enum": ["key", "best", "watch"] },
        "score": { "$ref": "#/definitions/score" },
        "keywords": { "$ref": "#/definitions/short_keyword_array" },
        "evidence_keys": { "$ref": "#/definitions/evidence_keys" }
      }
    },
    "window_candidate": {
      "type": "object",
      "required": [
        "date",
        "time_range_label",
        "score",
        "usage_keywords",
        "tone_code",
        "theme_code",
        "evidence_keys",
        "source_snapshot_keys"
      ],
      "additionalProperties": false,
      "properties": {
        "date": { "$ref": "#/definitions/date" },
        "time_range_label": { "type": "string", "pattern": "^\\d{2}:\\d{2}[-–]\\d{2}:\\d{2}$" },
        "score": { "$ref": "#/definitions/score" },
        "usage_keywords": { "$ref": "#/definitions/short_keyword_array" },
        "tone_code": { "type": "string", "maxLength": 64 },
        "theme_code": { "type": "string", "maxLength": 64 },
        "evidence_keys": { "$ref": "#/definitions/evidence_keys" },
        "source_snapshot_keys": { "$ref": "#/definitions/source_snapshot_keys" }
      }
    },
    "domain_candidate": {
      "type": "object",
      "required": ["domain_code", "weight", "keywords", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "domain_code": { "type": "string", "maxLength": 64 },
        "weight": { "$ref": "#/definitions/score" },
        "keywords": { "$ref": "#/definitions/short_keyword_array" },
        "evidence_keys": { "$ref": "#/definitions/evidence_keys" }
      }
    },
    "repeating_arc": {
      "type": "object",
      "required": ["signature_code", "dates", "dominant_keywords", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "signature_code": { "type": "string", "maxLength": 160 },
        "dates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/date" }
        },
        "dominant_keywords": { "$ref": "#/definitions/short_keyword_array" },
        "evidence_keys": { "$ref": "#/definitions/evidence_keys" }
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "evidence_key",
        "snapshot_key",
        "date",
        "fact_type",
        "transiting_object",
        "aspect",
        "natal_target",
        "natal_house",
        "theme_code",
        "tone_code",
        "score"
      ],
      "additionalProperties": false,
      "properties": {
        "evidence_key": { "type": "string", "minLength": 1, "maxLength": 120 },
        "snapshot_key": { "$ref": "#/definitions/snapshot_key" },
        "date": { "$ref": "#/definitions/date" },
        "fact_type": { "type": ["string", "null"] },
        "transiting_object": { "type": ["string", "null"] },
        "aspect": { "type": ["string", "null"] },
        "natal_target": { "type": ["string", "null"] },
        "natal_house": { "type": ["integer", "null"] },
        "theme_code": { "type": "string", "maxLength": 64 },
        "tone_code": { "type": "string", "maxLength": 64 },
        "score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    }
  }
}
