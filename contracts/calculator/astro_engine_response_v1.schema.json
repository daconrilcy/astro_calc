{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astral-calculation.local/schemas/astro_engine_response_v1.schema.json",
  "title": "Astro Engine Response v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "response_contract_version",
    "request_echo",
    "calculation_result",
    "audit_payload",
    "llm_payload"
  ],
  "properties": {
    "response_contract_version": {
      "const": "astro_engine_response_v1"
    },
    "request_echo": {
      "$ref": "#/$defs/request_echo"
    },
    "calculation_result": {
      "$ref": "#/$defs/calculation_result"
    },
    "audit_payload": {
      "$ref": "#/$defs/audit_payload"
    },
    "llm_payload": {
      "type": "object"
    }
  },
  "$defs": {
    "request_echo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "calculation_type",
        "birth_datetime_local",
        "birth_timezone",
        "birth_datetime_utc",
        "location",
        "projection_level"
      ],
      "properties": {
        "calculation_type": { "type": "string" },
        "birth_datetime_local": { "type": "string" },
        "birth_timezone": { "type": "string" },
        "birth_datetime_utc": { "type": "string" },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "required": ["latitude", "longitude"],
          "properties": {
            "label": { "type": ["string", "null"] },
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "projection_level": {
          "type": "string",
          "enum": ["compact", "standard", "rich", "expert"]
        }
      }
    },
    "calculation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "chart_calculation_id",
        "engine_version",
        "ephemeris_version",
        "raw_payload_contract_version",
        "llm_projection_contract_version"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["completed", "failed"]
        },
        "chart_calculation_id": { "type": "integer", "minimum": 1 },
        "engine_version": { "type": "string" },
        "ephemeris_version": { "type": "string" },
        "raw_payload_contract_version": { "type": "string" },
        "llm_projection_contract_version": { "type": "string" }
      }
    },
    "audit_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_version", "payload"],
      "properties": {
        "contract_version": { "type": "string" },
        "payload": { "type": "object" }
      }
    }
  }
}
