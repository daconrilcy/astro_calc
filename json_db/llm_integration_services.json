    "service_response_contract": "string",
    "calculation_output_contract": "string|null",
    "reading_output_contract": "string",
    "sync_endpoint": "string|null",
    "async_endpoint": "string",
    "supports_async": "boolean",
    "supports_sync_legacy": "boolean",
    "supports_mercure": "boolean",
    "availability": "string",
