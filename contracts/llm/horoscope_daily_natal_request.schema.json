{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_daily_natal_request",
  "type": "object",
  "required": [
    "date",
    "timezone",
    "target_language",
    "chart_calculation_id"
  ],
  "additionalProperties": false,
  "properties": {
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "timezone": {
      "type": "string",
      "minLength": 1,
      "examples": ["Europe/Paris"]
    },
    "target_language": {
      "type": "string",
      "minLength": 2,
      "maxLength": 8,
      "examples": ["fr"]
    },
    "chart_calculation_id": {
      "type": "string",
      "minLength": 1
    },
    "audience_level": {
      "type": "string",
      "enum": ["general", "beginner", "intermediate", "expert"],
      "default": "general"
    }
  }
}
