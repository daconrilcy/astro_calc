  "name": "prediction_object_category_weights",
  "structure": {
    "id": "integer, primary key",
    "reference_version_id": "integer|null, FK -> astral_reference_versions.id",
    "chart_object_id": "integer, FK -> astral_chart_objects.id",
    "prediction_category_id": "integer, FK -> prediction_categories.id",
    "weight": "number",
    "influence_role": "string",
