{
  "name": "astral_dominance_score_profiles",
  "structure": {
    "id": "integer, primary key",
    "code": "string",
    "label": "string",
    "tradition_code": "string",
    "description": "string",
    "is_active": "boolean",
    "reference_version_id": "integer|null, FK -> astral_reference_versions.id",
    "constraints": {
      "unique_key": [
        "reference_version_id",
        "code"
      ],
      "checks": [
        {
          "name": "active_requires_reference_version",
          "expression": "NOT is_active OR reference_version_id IS NOT NULL"
        }
      ]
    }
  },
  "data": [
    {
      "id": 2,
      "code": "natal_standard_v1",
      "label": "Natal standard dominance profile v1",
      "tradition_code": "modern",
      "description": "Profil standard pour calculer les planetes dominantes d'un theme natal.",
      "is_active": true,
      "reference_version_id": 1
    }
  ]
}
