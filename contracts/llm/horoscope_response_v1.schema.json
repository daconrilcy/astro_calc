{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_response_v1",
  "type": "object",
  "required": [
    "contract_version",
    "service_code",
    "period",
    "summary",
    "slots",
    "watch_points",
    "opportunities",
    "evidence_summary",
    "quality"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "const": "horoscope_response_v1" },
    "service_code": { "const": "horoscope_basic_daily_natal_3_slots" },
    "period": {
      "type": "object",
      "required": ["date", "timezone"],
      "properties": {
        "date": { "type": "string" },
        "timezone": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["title", "text"],
      "properties": {
        "title": { "type": "string" },
        "text": { "type": "string" }
      }
    },
    "slots": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["slot_code", "title", "text", "advice", "evidence_keys"],
        "properties": {
          "slot_code": { "type": "string" },
          "title": { "type": "string" },
          "theme": { "type": "string" },
          "tone": { "type": "string" },
          "text": { "type": "string" },
          "advice": { "type": "string" },
          "best_for": {
            "type": "array",
            "items": { "type": "string" }
          },
          "watch_point": { "type": "string" },
          "evidence_keys": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    },
    "watch_points": { "type": "array" },
    "opportunities": { "type": "array" },
    "evidence_summary": { "type": "array" },
    "quality": { "type": "object" }
  }
}
