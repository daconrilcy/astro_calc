{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astral-calculation.local/schemas/llm_projection_natal_simplified_v1.schema.json",
  "title": "LLM Projection Natal Simplified v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_code",
    "allowed_fact_codes",
    "allowed_astro_basis_fact_ids",
    "blocked_interpretation_fact_codes",
    "excluded_feature_codes",
    "profile_excluded_feature_codes",
    "allowed_limitation_mentions"
  ],
  "properties": {
    "profile_code": { "const": "natal_simplified" },
    "allowed_fact_codes": { "type": "array", "items": { "type": "string" } },
    "allowed_astro_basis_fact_ids": { "type": "array", "items": { "type": "string" } },
    "blocked_interpretation_fact_codes": { "type": "array", "items": { "type": "string" } },
    "excluded_feature_codes": { "type": "array", "items": { "type": "string" } },
    "profile_excluded_feature_codes": { "type": "array", "items": { "type": "string" } },
    "allowed_limitation_mentions": { "type": "array", "items": { "type": "string" } },
    "forbidden_interpretation_topics": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Agrégat dérivé des sujets d'interprétation exclus (prompt / doc)."
    },
    "forbidden_topics": {
      "type": "array",
      "items": { "type": "string" },
      "deprecated": true,
      "description": "Alias déprécié de forbidden_interpretation_topics (compat lecture)."
    }
  }
}
