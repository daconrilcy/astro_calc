{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_premium_daily_local_request_v1",
  "type": "object",
  "required": [
    "date",
    "timezone",
    "target_language",
    "chart_calculation_id",
    "location"
  ],
  "additionalProperties": false,
  "properties": {
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "timezone": {
      "type": "string",
      "minLength": 1,
      "examples": ["Europe/Paris"]
    },
    "target_language": {
      "type": "string",
      "minLength": 2,
      "maxLength": 8,
      "examples": ["fr"]
    },
    "chart_calculation_id": {
      "type": "string",
      "minLength": 1
    },
    "location": {
      "type": "object",
      "required": ["latitude", "longitude"],
      "additionalProperties": false,
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "audience_level": {
      "type": "string",
      "enum": ["general", "beginner", "intermediate", "expert"],
      "default": "general"
    },
    "detail_level": {
      "type": "string",
      "enum": ["premium_rich"],
      "default": "premium_rich"
    }
  }
}
