{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astral-calculation.local/schemas/natal_structured_v10.schema.json",
  "title": "Natal Structured Payload v10",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product_code",
    "chart_calculation_id",
    "reference_version_id",
    "subject_label",
    "birth_datetime_utc",
    "llm_handoff_contract",
    "chart_context",
    "positions",
    "angles",
    "dignities",
    "chart_emphasis",
    "rulership_context",
    "signals",
    "reading_plan",
    "drafting_plan"
  ],
  "properties": {
    "product_code": { "const": "basic" },
    "chart_calculation_id": { "type": "integer", "minimum": 1 },
    "reference_version_id": { "type": "integer", "minimum": 1 },
    "subject_label": { "type": ["string", "null"] },
    "birth_datetime_utc": { "type": "string", "format": "date-time" },
    "llm_handoff_contract": { "$ref": "#/$defs/llm_handoff_contract" },
    "chart_context": { "$ref": "#/$defs/chart_context" },
    "positions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/position" }
    },
    "angles": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "allOf": [
        { "contains": { "properties": { "angle_code": { "const": "ascendant" } }, "required": ["angle_code"] } },
        { "contains": { "properties": { "angle_code": { "const": "descendant" } }, "required": ["angle_code"] } },
        { "contains": { "properties": { "angle_code": { "const": "mc" } }, "required": ["angle_code"] } },
        { "contains": { "properties": { "angle_code": { "const": "ic" } }, "required": ["angle_code"] } }
      ],
      "items": { "$ref": "#/$defs/angle" }
    },
    "dignities": {
      "type": "array",
      "items": { "$ref": "#/$defs/dignity" }
    },
    "chart_emphasis": { "$ref": "#/$defs/chart_emphasis" },
    "rulership_context": { "$ref": "#/$defs/rulership_context" },
    "signals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": { "$ref": "#/$defs/signal" }
    },
    "reading_plan": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/reading_plan_item" }
    },
    "drafting_plan": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/drafting_plan_item" }
    }
  },
  "$defs": {
    "llm_handoff_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "payload_language_code",
        "target_language_policy",
        "audience_level",
        "tone",
        "must_use",
        "must_not",
        "output_format"
      ],
      "properties": {
        "contract_version": { "const": "natal_structured_v10" },
        "payload_language_code": { "const": "en" },
        "target_language_policy": { "const": "provided_by_llm_service" },
        "audience_level": { "const": "beginner" },
        "tone": { "type": "string", "minLength": 1 },
        "must_use": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": [
              "chart_context",
              "chart_emphasis",
              "rulership_context",
              "dignities",
              "angles",
              "signals",
              "reading_plan",
              "drafting_plan"
            ]
          },
          "allOf": [
            { "contains": { "const": "chart_context" } },
            { "contains": { "const": "chart_emphasis" } },
            { "contains": { "const": "rulership_context" } },
            { "contains": { "const": "dignities" } },
            { "contains": { "const": "angles" } },
            { "contains": { "const": "signals" } },
            { "contains": { "const": "reading_plan" } },
            { "contains": { "const": "drafting_plan" } }
          ]
        },
        "must_not": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "items": { "type": "string", "minLength": 1 },
          "allOf": [
            { "contains": { "const": "invent facts not present in source signals" } },
            { "contains": { "const": "mention technical IDs" } },
            { "contains": { "const": "list placements mechanically" } },
            { "contains": { "const": "translate technical keys such as signal_key, theme_code, semantic_tags, slot, or aggregation_group" } },
            { "contains": { "const": "expose raw evidence unless explicitly requested" } },
            { "contains": { "const": "treat chart_emphasis as a standalone section instead of weighting context" } },
            { "contains": { "const": "treat chart_context as a standalone section instead of contextual weighting" } },
            { "contains": { "const": "treat rulership_context as a standalone section instead of contextual weighting" } },
            { "contains": { "const": "make deterministic or fatalistic predictions" } }
          ]
        },
        "output_format": { "const": "structured_sections" }
      }
    },
    "chart_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chart_type",
        "zodiacal_reference_system_id",
        "coordinate_reference_system_id",
        "house_system_id",
        "reference_version_id",
        "payload_contract",
        "calculation_reliability",
        "sect",
        "hemisphere_emphasis"
      ],
      "properties": {
        "chart_type": { "const": "natal" },
        "zodiacal_reference_system_id": { "type": "integer", "minimum": 1 },
        "coordinate_reference_system_id": { "type": "integer", "minimum": 1 },
        "house_system_id": { "type": "integer", "minimum": 1 },
        "reference_version_id": { "type": "integer", "minimum": 1 },
        "payload_contract": { "$ref": "#/$defs/payload_contract" },
        "calculation_reliability": { "$ref": "#/$defs/calculation_reliability" },
        "sect": { "$ref": "#/$defs/sect_context" },
        "hemisphere_emphasis": { "$ref": "#/$defs/hemisphere_emphasis" }
      }
    },
    "payload_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "calculation_scope",
        "interpretation_scope",
        "projection_depth",
        "writing_contract"
      ],
      "properties": {
        "contract_version": { "const": "natal_structured_v10" },
        "calculation_scope": { "const": "full_natal" },
        "interpretation_scope": { "const": "structured_interpretation" },
        "projection_depth": { "const": "rich" },
        "writing_contract": { "const": "provided_by_llm_service" }
      }
    },
    "calculation_reliability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["birth_time_precision_required", "house_system_sensitive"],
      "properties": {
        "birth_time_precision_required": { "const": true },
        "house_system_sensitive": { "const": true }
      }
    },
    "sect_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chart_sect", "sun_horizon_position", "source"],
      "properties": {
        "chart_sect": { "enum": ["day", "night", "all"] },
        "sun_horizon_position": { "$ref": "#/$defs/horizon_position" },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "hemisphere_emphasis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "above_horizon_count",
        "count_scope",
        "below_horizon_count",
        "on_horizon_count",
        "interpretive_hint"
      ],
      "properties": {
        "count_scope": { "const": "mobile_chart_objects_only" },
        "above_horizon_count": { "type": "integer", "minimum": 0 },
        "below_horizon_count": { "type": "integer", "minimum": 0 },
        "on_horizon_count": { "type": "integer", "minimum": 0 },
        "interpretive_hint": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "object_context": {
                "properties": { "role": { "const": "angle" } },
                "required": ["role"]
              }
            },
            "required": ["object_context"]
          },
          "then": {
            "properties": {
              "visibility_context": { "$ref": "#/$defs/angle_visibility_context" }
            }
          },
          "else": {
            "properties": {
              "visibility_context": { "$ref": "#/$defs/mobile_visibility_context" }
            }
          }
        }
      ],
      "required": [
        "object_code",
        "object_name",
        "longitude_deg",
        "sign_id",
        "sign_code",
        "sign_name",
        "house_id",
        "house_number",
        "house_name",
        "motion_state_id",
        "sign_context",
        "house_context",
        "house_modality",
        "object_context",
        "motion_context",
        "dignity_context",
        "visibility_context"
      ],
      "properties": {
        "object_code": { "type": "string", "minLength": 1 },
        "object_name": { "type": "string", "minLength": 1 },
        "longitude_deg": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "sign_id": { "type": "integer", "minimum": 1 },
        "sign_code": { "type": "string", "minLength": 1 },
        "sign_name": { "type": "string", "minLength": 1 },
        "house_id": { "type": ["integer", "null"], "minimum": 1 },
        "house_number": { "type": ["integer", "null"], "minimum": 1, "maximum": 12 },
        "house_name": { "type": ["string", "null"] },
        "motion_state_id": { "type": ["integer", "null"], "minimum": 1 },
        "sign_context": { "$ref": "#/$defs/sign_context" },
        "house_context": { "$ref": "#/$defs/house_context" },
        "house_modality": { "$ref": "#/$defs/house_modality" },
        "object_context": { "$ref": "#/$defs/object_context" },
        "motion_context": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/motion_context" }
          ]
        },
        "dignity_context": { "type": "array" },
        "visibility_context": { "$ref": "#/$defs/visibility_context" }
      }
    },
    "visibility_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "horizon_position_id",
        "horizon_position",
        "altitude_deg",
        "is_visible",
        "source"
      ],
      "properties": {
        "horizon_position_id": { "type": "integer", "minimum": 1 },
        "horizon_position": { "$ref": "#/$defs/horizon_position" },
        "altitude_deg": { "type": ["number", "null"] },
        "is_visible": { "type": ["boolean", "null"] },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "mobile_visibility_context": {
      "allOf": [
        { "$ref": "#/$defs/visibility_context" },
        {
          "type": "object",
          "properties": {
            "altitude_deg": { "type": "number" },
            "is_visible": { "type": "boolean" },
            "source": { "const": "calculated_altitude" }
          }
        }
      ]
    },
    "angle_visibility_context": {
      "allOf": [
        { "$ref": "#/$defs/visibility_context" },
        {
          "type": "object",
          "properties": {
            "altitude_deg": { "type": "null" },
            "is_visible": { "type": "null" },
            "source": { "const": "angle_context" }
          }
        }
      ]
    },
    "horizon_position": {
      "enum": ["above_horizon", "below_horizon", "on_horizon"]
    },
    "angle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "angle_code",
        "angle_name",
        "axis",
        "opposite_angle_code",
        "longitude_deg",
        "sign_id",
        "sign_code",
        "sign_name",
        "house_id",
        "house_number",
        "house_name"
      ],
      "properties": {
        "angle_code": { "enum": ["ascendant", "descendant", "mc", "ic"] },
        "angle_name": { "type": "string", "minLength": 1 },
        "axis": { "enum": ["horizontal", "vertical"] },
        "opposite_angle_code": { "enum": ["ascendant", "descendant", "mc", "ic"] },
        "longitude_deg": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "sign_id": { "type": "integer", "minimum": 1 },
        "sign_code": { "type": "string", "minLength": 1 },
        "sign_name": { "type": "string", "minLength": 1 },
        "house_id": { "type": "integer", "minimum": 1 },
        "house_number": { "type": "integer", "minimum": 1, "maximum": 12 },
        "house_name": { "type": "string", "minLength": 1 }
      }
    },
    "dignity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_code",
        "object_name",
        "sign_id",
        "sign_code",
        "sign_name",
        "dignity_type",
        "dignity_label",
        "polarity",
        "strength_score",
        "signal_key"
      ],
      "properties": {
        "object_code": { "type": "string", "minLength": 1 },
        "object_name": { "type": "string", "minLength": 1 },
        "sign_id": { "type": "integer", "minimum": 1 },
        "sign_code": { "type": "string", "minLength": 1 },
        "sign_name": { "type": "string", "minLength": 1 },
        "dignity_type": { "type": "string", "minLength": 1 },
        "dignity_label": { "type": "string", "minLength": 1 },
        "polarity": { "enum": ["dignity", "debility"] },
        "strength_score": { "type": "number", "exclusiveMinimum": 0 },
        "signal_key": { "type": ["string", "null"] }
      }
    },
    "chart_emphasis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dominant_signs", "dominant_houses", "dominant_objects"],
      "properties": {
        "dominant_signs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/dominant_sign" }
        },
        "dominant_houses": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/dominant_house" }
        },
        "dominant_objects": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "$ref": "#/$defs/dominant_object" }
        }
      }
    },
    "dominant_sign": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sign_code", "score", "reasons"],
      "properties": {
        "sign_code": { "type": "string", "minLength": 1 },
        "score": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "reasons": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "dominant_house": {
      "type": "object",
      "additionalProperties": false,
      "required": ["house_number", "theme_code", "score", "reasons"],
      "properties": {
        "house_number": { "type": "integer", "minimum": 1, "maximum": 12 },
        "theme_code": { "type": "string", "minLength": 1 },
        "score": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "reasons": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "dominant_object": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_code", "score", "reasons"],
      "properties": {
        "object_code": { "type": "string", "minLength": 1 },
        "score": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "reasons": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "rulership_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ascendant_ruler",
        "mc_ruler",
        "dominant_house_rulers",
        "dominant_sign_rulers",
        "dispositor_links",
        "rulership_chains",
        "final_dispositors"
      ],
      "properties": {
        "ascendant_ruler": {
          "$ref": "#/$defs/ruler_context"
        },
        "mc_ruler": {
          "$ref": "#/$defs/ruler_context"
        },
        "dominant_house_rulers": {
          "type": "array",
          "items": { "$ref": "#/$defs/ruler_context" }
        },
        "dominant_sign_rulers": {
          "type": "array",
          "items": { "$ref": "#/$defs/ruler_context" }
        },
        "dispositor_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/dispositor_link" }
        },
        "rulership_chains": {
          "type": "array",
          "items": { "$ref": "#/$defs/rulership_chain" }
        },
        "final_dispositors": {
          "type": "array",
          "items": { "$ref": "#/$defs/final_dispositor" }
        }
      }
    },
    "ruler_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_key",
        "source_kind",
        "source_code",
        "sign_code",
        "ruler_object_codes",
        "ruler_object_code",
        "ruler_position_signal_key",
        "ruler_house_number",
        "ruler_sign_code",
        "interpretive_role",
        "strength_context",
        "ruler_sources",
        "interpretive_hint"
      ],
      "properties": {
        "context_key": { "type": "string", "minLength": 1 },
        "source_kind": { "enum": ["angle", "dominant_house", "dominant_sign"] },
        "source_code": { "type": "string", "minLength": 1 },
        "sign_code": { "type": "string", "minLength": 1 },
        "ruler_object_codes": { "$ref": "#/$defs/non_empty_string_array" },
        "ruler_object_code": { "type": "string", "minLength": 1 },
        "ruler_position_signal_key": { "type": ["string", "null"], "minLength": 1 },
        "ruler_house_number": { "type": ["integer", "null"], "minimum": 1, "maximum": 12 },
        "ruler_sign_code": { "type": ["string", "null"], "minLength": 1 },
        "interpretive_role": { "type": "string", "minLength": 1 },
        "strength_context": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "ruler_sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ruler_source" }
        },
        "interpretive_hint": { "type": "string", "minLength": 1 }
      }
    },
    "ruler_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_code",
        "reference_version_id",
        "astral_system_id",
        "astral_system_code",
        "dignity_type",
        "weight",
        "is_primary"
      ],
      "properties": {
        "object_code": { "type": "string", "minLength": 1 },
        "reference_version_id": { "type": ["integer", "null"], "minimum": 1 },
        "astral_system_id": { "type": "integer", "minimum": 1 },
        "astral_system_code": { "type": "string", "minLength": 1 },
        "dignity_type": { "const": "domicile" },
        "weight": { "type": "number" },
        "is_primary": { "type": "boolean" }
      }
    },
    "dispositor_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_code",
        "object_sign_code",
        "dispositor_object_code",
        "dispositor_signal_key",
        "ruler_sources",
        "interpretive_hint"
      ],
      "properties": {
        "object_code": { "type": "string", "minLength": 1 },
        "object_sign_code": { "type": "string", "minLength": 1 },
        "dispositor_object_code": { "type": "string", "minLength": 1 },
        "dispositor_signal_key": { "type": "string", "minLength": 1 },
        "ruler_sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ruler_source" }
        },
        "interpretive_hint": { "type": "string", "minLength": 1 }
      }
    },
    "rulership_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_code", "chain", "termination"],
      "properties": {
        "object_code": { "type": "string", "minLength": 1 },
        "chain": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "items": { "type": "string", "minLength": 1 }
        },
        "termination": {
          "enum": ["final_dispositor", "mutual_reception", "cycle", "max_depth", "unresolved"]
        }
      }
    },
    "final_dispositor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_code", "disposition_type", "source_objects"],
      "properties": {
        "object_code": { "type": "string", "minLength": 1 },
        "disposition_type": { "enum": ["final_dispositor", "mutual_reception", "cycle"] },
        "source_objects": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_key",
        "theme_code",
        "title",
        "summary",
        "priority_score",
        "confidence_score",
        "interpretive_hint",
        "semantic_tags",
        "source_weight",
        "aggregation_group",
        "writing_guidance",
        "aspect_context",
        "evidence"
      ],
      "properties": {
        "signal_key": {
          "type": "string",
          "pattern": "^(object_position|angle|dignity|cluster|aspect):",
          "minLength": 1
        },
        "theme_code": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "priority_score": { "type": "number", "minimum": 0 },
        "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "interpretive_hint": { "type": "string", "minLength": 1 },
        "semantic_tags": { "$ref": "#/$defs/non_empty_string_array" },
        "source_weight": { "type": "number", "minimum": 0 },
        "aggregation_group": { "type": "string", "minLength": 1 },
        "writing_guidance": { "type": "string", "minLength": 1 },
        "aspect_context": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/aspect_context" }
          ]
        },
        "evidence": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "properties": { "signal_key": { "pattern": "^aspect:" } }, "required": ["signal_key"] },
          "then": {
            "properties": {
              "aspect_context": { "$ref": "#/$defs/aspect_context" },
              "evidence": { "$ref": "#/$defs/aspect_evidence" }
            }
          }
        },
        {
          "if": { "properties": { "signal_key": { "pattern": "^object_position:" } }, "required": ["signal_key"] },
          "then": {
            "properties": {
              "aspect_context": { "type": "null" },
              "evidence": { "$ref": "#/$defs/object_position_evidence" }
            }
          }
        },
        {
          "if": { "properties": { "signal_key": { "pattern": "^angle:" } }, "required": ["signal_key"] },
          "then": {
            "properties": {
              "aspect_context": { "type": "null" },
              "evidence": { "$ref": "#/$defs/angle_evidence" }
            }
          }
        },
        {
          "if": { "properties": { "signal_key": { "pattern": "^dignity:" } }, "required": ["signal_key"] },
          "then": {
            "properties": {
              "aspect_context": { "type": "null" },
              "evidence": { "$ref": "#/$defs/dignity_evidence" }
            }
          }
        },
        {
          "if": { "properties": { "signal_key": { "pattern": "^cluster:" } }, "required": ["signal_key"] },
          "then": {
            "properties": {
              "aspect_context": { "type": "null" },
              "evidence": { "$ref": "#/$defs/cluster_evidence" }
            }
          }
        },
        {
          "not": {
            "properties": {
              "signal_key": {
                "pattern": "^aspect:(ascendant|descendant|mc|ic):(ascendant|descendant|mc|ic):"
              }
            },
            "required": ["signal_key"]
          }
        }
      ]
    },
    "aspect_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aspect_family",
        "primary_valence",
        "intensity_modifier",
        "secondary_effect",
        "dynamic_quality",
        "phase_state",
        "valence_family",
        "is_tonal_valence",
        "is_intensity_modifier",
        "writing_guidance"
      ],
      "properties": {
        "aspect_family": { "type": "string", "minLength": 1 },
        "primary_valence": { "type": ["string", "null"], "minLength": 1 },
        "intensity_modifier": { "type": ["string", "null"], "minLength": 1 },
        "secondary_effect": { "type": ["string", "null"], "minLength": 1 },
        "dynamic_quality": {
          "enum": [
            "flow",
            "tension",
            "adjustment",
            "intensification",
            "symbolic",
            "integration",
            "contextual"
          ]
        },
        "phase_state": { "type": "string", "minLength": 1 },
        "valence_family": { "type": "string", "minLength": 1 },
        "is_tonal_valence": { "type": "boolean" },
        "is_intensity_modifier": { "type": "boolean" },
        "writing_guidance": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "properties": { "primary_valence": { "type": "string", "minLength": 1 } }, "required": ["primary_valence"] },
        { "properties": { "intensity_modifier": { "type": "string", "minLength": 1 } }, "required": ["intensity_modifier"] },
        { "properties": { "secondary_effect": { "type": "string", "minLength": 1 } }, "required": ["secondary_effect"] }
      ]
    },
    "sign_context": {
      "type": "object",
      "additionalProperties": true,
      "required": ["element", "modality", "polarity"],
      "properties": {
        "element": { "type": "string", "minLength": 1 },
        "modality": { "type": "string", "minLength": 1 },
        "polarity": { "type": "string", "minLength": 1 }
      }
    },
    "house_context": {
      "type": "object",
      "additionalProperties": true,
      "required": ["theme_code"],
      "properties": {
        "theme_code": { "type": "string", "minLength": 1 }
      }
    },
    "house_modality": {
      "type": "object",
      "additionalProperties": true,
      "required": ["code"],
      "properties": {
        "code": { "type": "string", "minLength": 1 }
      }
    },
    "object_context": {
      "type": "object",
      "additionalProperties": true,
      "required": ["role"],
      "properties": {
        "role": { "type": "string", "minLength": 1 }
      }
    },
    "motion_context": {
      "type": "object",
      "additionalProperties": true,
      "required": ["motion_state"],
      "properties": {
        "motion_state": { "type": "string", "minLength": 1 }
      }
    },
    "placement_context": {
      "type": "object",
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "properties": {
              "object_context": {
                "properties": { "role": { "const": "angle" } },
                "required": ["role"]
              }
            },
            "required": ["object_context"]
          },
          "then": {
            "properties": {
              "visibility_context": { "$ref": "#/$defs/angle_visibility_context" }
            }
          },
          "else": {
            "properties": {
              "visibility_context": { "$ref": "#/$defs/mobile_visibility_context" }
            }
          }
        }
      ],
      "required": [
        "sign_context",
        "house_context",
        "house_modality",
        "object_context",
        "motion_context",
        "visibility_context"
      ],
      "properties": {
        "sign_context": { "$ref": "#/$defs/sign_context" },
        "house_context": { "$ref": "#/$defs/house_context" },
        "house_modality": { "$ref": "#/$defs/house_modality" },
        "object_context": { "$ref": "#/$defs/object_context" },
        "motion_context": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/motion_context" }
          ]
        },
        "visibility_context": { "$ref": "#/$defs/visibility_context" }
      }
    },
    "object_position_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fact_type",
        "object_code",
        "sign_code",
        "placement_context",
        "essential_dignities"
      ],
      "properties": {
        "fact_type": { "const": "object_position" },
        "object_code": { "type": "string", "minLength": 1 },
        "sign_code": { "type": "string", "minLength": 1 },
        "placement_context": { "$ref": "#/$defs/placement_context" },
        "essential_dignities": { "type": "array" }
      }
    },
    "angle_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fact_type",
        "angle_code",
        "opposite_angle_code",
        "opposite_angle_object_code",
        "sign_code",
        "placement_context"
      ],
      "properties": {
        "fact_type": { "const": "chart_angle" },
        "angle_code": { "enum": ["ascendant", "descendant", "mc", "ic"] },
        "opposite_angle_code": { "type": "string", "minLength": 1 },
        "opposite_angle_object_code": { "enum": ["ascendant", "descendant", "mc", "ic"] },
        "sign_code": { "type": "string", "minLength": 1 },
        "placement_context": { "$ref": "#/$defs/placement_context" }
      }
    },
    "aspect_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fact_type",
        "source_object_code",
        "target_object_code",
        "aspect_code",
        "strength_score"
      ],
      "properties": {
        "fact_type": { "const": "aspect" },
        "source_object_code": { "type": "string", "minLength": 1 },
        "target_object_code": { "type": "string", "minLength": 1 },
        "aspect_code": { "type": "string", "minLength": 1 },
        "strength_score": { "type": "number", "minimum": 0 }
      }
    },
    "dignity_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["fact_type", "chart_object", "sign_code", "dignity_type"],
      "properties": {
        "fact_type": { "const": "essential_dignity" },
        "chart_object": { "type": "string", "minLength": 1 },
        "sign_code": { "type": "string", "minLength": 1 },
        "dignity_type": { "type": "string", "minLength": 1 }
      }
    },
    "cluster_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fact_type",
        "cluster_type",
        "sign_code",
        "house_number",
        "house_theme_code",
        "source_signals",
        "source_objects"
      ],
      "properties": {
        "fact_type": { "const": "position_cluster" },
        "cluster_type": { "type": "string", "minLength": 1 },
        "sign_code": { "type": "string", "minLength": 1 },
        "house_number": { "type": "integer", "minimum": 1, "maximum": 12 },
        "house_theme_code": { "type": "string", "minLength": 1 },
        "source_signals": { "$ref": "#/$defs/non_empty_string_array" },
        "source_objects": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "reading_plan_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot",
        "title",
        "source_signal_keys",
        "primary_signal_keys",
        "secondary_slot_candidates"
      ],
      "properties": {
        "slot": { "$ref": "#/$defs/reading_slot" },
        "title": { "type": "string", "minLength": 1 },
        "source_signal_keys": { "$ref": "#/$defs/non_empty_string_array" },
        "primary_signal_keys": { "$ref": "#/$defs/non_empty_string_array" },
        "secondary_slot_candidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/secondary_slot_candidate" }
        }
      }
    },
    "drafting_plan_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot",
        "section_title",
        "source_signal_keys",
        "primary_signal_keys",
        "secondary_slot_candidates",
        "emphasis_refs",
        "context_refs",
        "writing_objective",
        "max_words",
        "avoid"
      ],
      "properties": {
        "slot": { "$ref": "#/$defs/reading_slot" },
        "section_title": { "type": "string", "minLength": 1 },
        "source_signal_keys": { "$ref": "#/$defs/non_empty_string_array" },
        "primary_signal_keys": { "$ref": "#/$defs/non_empty_string_array" },
        "secondary_slot_candidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/secondary_slot_candidate" }
        },
        "emphasis_refs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dominant_signs", "dominant_houses", "dominant_objects"],
          "properties": {
            "dominant_signs": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "dominant_houses": {
              "type": "array",
              "items": { "type": "integer", "minimum": 1, "maximum": 12 }
            },
            "dominant_objects": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "context_refs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["chart_context", "rulership_context"],
          "properties": {
            "chart_context": {
              "type": "array",
              "items": {
                "enum": ["sect", "hemisphere_emphasis"]
              }
            },
            "rulership_context": {
              "type": "array",
              "items": {
                "enum": [
                  "ascendant_ruler",
                  "dominant_sign_rulers",
                  "dominant_house_rulers"
                ]
              }
            }
          }
        },
        "writing_objective": { "type": "string", "minLength": 1 },
        "max_words": { "type": "integer", "minimum": 1 },
        "avoid": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "secondary_slot_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal_key", "primary_slot", "candidate_slot"],
      "properties": {
        "signal_key": { "type": "string", "minLength": 1 },
        "primary_slot": { "$ref": "#/$defs/reading_slot" },
        "candidate_slot": { "$ref": "#/$defs/reading_slot" }
      }
    },
    "reading_slot": {
      "enum": [
        "core_identity",
        "dominant_cluster",
        "main_tension_or_support",
        "expression_style",
        "background_factors"
      ]
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
