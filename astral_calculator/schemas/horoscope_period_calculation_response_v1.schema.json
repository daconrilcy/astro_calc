{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_period_calculation_response_v1",
  "type": "object",
  "required": [
    "contract_version",
    "service_code",
    "period_resolution",
    "scan_plan",
    "snapshots",
    "calculation_warnings",
    "evidence_keys"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "const": "horoscope_period_calculation_response_v1" },
    "service_code": { "const": "horoscope_basic_next_7_days_natal" },
    "period_resolution": { "type": "object" },
    "scan_plan": { "type": "object" },
    "snapshots": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "required": [
          "snapshot_key",
          "date",
          "reference_datetime_utc",
          "sky_snapshot",
          "moon_context",
          "transits_to_natal",
          "current_sky_aspects",
          "natal_house_activations"
        ],
        "additionalProperties": false,
        "properties": {
          "snapshot_key": { "type": "string" },
          "date": { "type": "string" },
          "reference_datetime_utc": { "type": "string" },
          "sky_snapshot": { "type": "object" },
          "moon_context": { "type": "object" },
          "transits_to_natal": { "type": "array" },
          "current_sky_aspects": { "type": "array" },
          "natal_house_activations": { "type": "array" },
          "calculation_warnings": { "type": "array" }
        }
      }
    },
    "calculation_warnings": { "type": "array" },
    "evidence_keys": { "type": "array", "items": { "type": "string" } }
  }
}
