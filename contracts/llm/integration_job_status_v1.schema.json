{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "integration_job_status_v1",
  "description": "Reponse GET /v1/jobs/{run_id}.",
  "type": "object",
  "required": ["run_id", "service_code", "status", "submitted_at"],
  "properties": {
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "service_code": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "safety_rejected",
        "cancelled",
        "expired"
      ]
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "poll_after_ms": {
      "type": "integer",
      "minimum": 0
    },
    "token_usage": {
      "type": ["object", "null"],
      "description": "Resume token_usage additif au niveau job, derive du reading terminal."
    },
    "result": {
      "description": "Enveloppe unifiee { calculation?, reading, reading_completeness? } si terminal success."
    },
    "error": {
      "type": ["object", "null"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": {
          "type": ["object", "null"],
          "description": "Details non bloquants ou techniques sur l'erreur terminale. Pour safety_rejected, contient notamment category, rule_id et violations."
        }
      }
    }
  }
}
