      "unique_key": [
        "reference_version_id",
        "chart_object_id",
        "prediction_category_id"
      ],
      "checks": [
        {
          "name": "weight_range",
          "expression": "weight >= 0 AND weight <= 1"
        },
        {
          "name": "influence_role_allowed",
          "expression": "influence_role IN ('primary', 'secondary', 'supporting', 'contextual')"
        }
      ]
    }
