{
  "name": "astral_chart_object_signal_profiles",
  "structure": {
    "id": "integer, primary key",
    "reference_version_id": "integer|null, FK -> astral_reference_versions.id",
    "chart_object_id": "integer, FK -> astral_chart_objects.id",
    "position_priority_base": "number",
    "angle_priority_base": "number|null",
    "source_weight": "number",
    "notes": "string|null",
    "constraints": {
      "unique_key": [
        "reference_version_id",
        "chart_object_id"
      ],
      "checks": [
        {
          "name": "position_priority_range",
          "expression": "position_priority_base >= 0 AND position_priority_base <= 100"
        },
        {
          "name": "angle_priority_range",
          "expression": "angle_priority_base IS NULL OR (angle_priority_base >= 0 AND angle_priority_base <= 100)"
        },
        {
          "name": "source_weight_range",
          "expression": "source_weight >= 0"
        }
      ]
    }
  },
