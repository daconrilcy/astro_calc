      ],
      "checks": [
        {
          "name": "calculation_mode_allowed",
          "expression": "calculation_mode IN ('none', 'simplified_natal', 'full_natal')"
        },
        {
          "name": "availability_allowed",
          "expression": "availability IN ('active', 'beta', 'planned', 'deprecated', 'disabled')"
        }
      ]
    }
