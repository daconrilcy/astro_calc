{
  "name": "astral_simplified_profile_feature_exclusions",
  "structure": {
    "id": "integer, primary key",
    "profile_code": "string",
    "computed_scope_code": "string|null",
    "feature_code": "string",
    "exclusion_kind": "string",
    "reason": "string",
    "sort_order": "integer",
    "is_active": "boolean",
    "constraints": {
      "unique_key": [
        "profile_code",
        "computed_scope_code",
        "feature_code",
        "exclusion_kind"
      ],
      "checks": [
        {
          "name": "feature_code_allowed",
          "expression": "feature_code IN ('ascendant', 'houses', 'sect', 'house_placements')"
        },
        {
          "name": "exclusion_kind_allowed",
          "expression": "exclusion_kind IN ('profile_interpretation_excluded')"
        }
      ]
    }
  },
