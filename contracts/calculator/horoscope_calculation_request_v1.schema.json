{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_calculation_request_v1",
  "type": "object",
  "required": [
    "contract_version",
    "service_code",
    "period",
    "chart_calculation_id",
    "slots"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "service_code": { "const": "horoscope_basic_daily_natal_3_slots" }
        },
        "required": ["service_code"]
      },
      "then": {
        "properties": {
          "slots": { "minItems": 3, "maxItems": 3 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "service_code": { "const": "horoscope_free_daily" }
        },
        "required": ["service_code"]
      },
      "then": {
        "properties": {
          "slots": { "minItems": 1, "maxItems": 1 }
        }
      }
    }
  ],
  "properties": {
    "contract_version": { "const": "horoscope_calculation_request_v1" },
    "service_code": {
      "enum": ["horoscope_basic_daily_natal_3_slots", "horoscope_free_daily"]
    },
    "chart_calculation_id": { "type": "string", "minLength": 1 },
    "period": {
      "type": "object",
      "required": ["date", "timezone"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string", "format": "date" },
        "timezone": { "type": "string", "minLength": 1 }
      }
    },
    "slots": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": [
          "slot_code",
          "start_local_time",
          "end_local_time",
          "reference_local_time"
        ],
        "additionalProperties": false,
        "properties": {
          "slot_code": { "type": "string" },
          "start_local_time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
          "end_local_time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
          "reference_local_time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" }
        }
      }
    }
  }
}
