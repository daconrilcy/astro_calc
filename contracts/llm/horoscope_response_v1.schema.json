{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_response_v1",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "contract_version",
        "service_code",
        "period",
        "summary",
        "slots",
        "watch_points",
        "opportunities",
        "evidence_summary",
        "quality"
      ],
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": "horoscope_response_v1" },
        "service_code": { "const": "horoscope_basic_daily_natal_3_slots" },
        "period": { "$ref": "#/definitions/period" },
        "summary": { "$ref": "#/definitions/summary" },
        "slots": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/definitions/public_slot" }
        },
        "watch_points": { "type": "array" },
        "opportunities": { "type": "array" },
        "evidence_summary": { "type": "array" },
        "quality": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": [
        "contract_version",
        "service_code",
        "period",
        "summary",
        "advice",
        "watch_point",
        "evidence_keys",
        "quality"
      ],
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": "horoscope_response_v1" },
        "service_code": { "const": "horoscope_free_daily" },
        "period": { "$ref": "#/definitions/period" },
        "summary": { "$ref": "#/definitions/summary" },
        "advice": { "type": "string", "minLength": 1 },
        "watch_point": { "type": "string", "minLength": 1 },
        "evidence_keys": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "type": "string" }
        },
        "quality": { "type": "object" }
      }
    }
  ],
  "definitions": {
    "period": {
      "type": "object",
      "required": ["date", "timezone"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "timezone": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["title", "text"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "text": { "type": "string" }
      }
    },
    "public_slot": {
      "type": "object",
      "required": ["slot_code", "title", "text", "advice", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "slot_code": { "type": "string" },
        "title": { "type": "string" },
        "theme": { "type": "string" },
        "tone": { "type": "string" },
        "text": { "type": "string" },
        "advice": { "type": "string" },
        "best_for": {
          "type": "array",
          "items": { "type": "string" }
        },
        "watch_point": { "type": "string" },
        "evidence_keys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    }
  }
}
