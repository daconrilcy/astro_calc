{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_period_interpretation_request_v1",
  "type": "object",
  "required": [
    "contract_version",
    "service_code",
    "period_resolution",
    "scan_plan",
    "target_language",
    "detail_profile_code",
    "week_overview_plan",
    "period_events",
    "main_events",
    "key_days",
    "best_days",
    "watch_days",
    "watch_summary_plan",
    "daily_plans",
    "domain_sections",
    "evidence"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "service_code": { "const": "horoscope_free_next_7_days_natal" } },
        "required": ["service_code"]
      },
      "then": {
        "properties": {
          "daily_plans": { "type": "array", "maxItems": 0 },
          "domain_sections": { "type": "array", "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": { "service_code": { "const": "horoscope_basic_next_7_days_natal" } },
        "required": ["service_code"]
      },
      "then": {
        "properties": {
          "daily_plans": { "type": "array", "minItems": 7, "maxItems": 7 },
          "domain_sections": { "type": "array", "minItems": 2, "maxItems": 5 }
        }
      }
    },
    {
      "if": {
        "properties": { "service_code": { "const": "horoscope_premium_next_7_days_natal" } },
        "required": ["service_code"]
      },
      "then": {
        "properties": {
          "daily_plans": { "type": "array", "minItems": 7, "maxItems": 7 },
          "domain_sections": { "type": "array", "minItems": 2, "maxItems": 5 }
        }
      }
    }
  ],
  "properties": {
    "contract_version": { "const": "horoscope_period_interpretation_request_v1" },
    "service_code": {
      "enum": [
        "horoscope_free_next_7_days_natal",
        "horoscope_basic_next_7_days_natal",
        "horoscope_premium_next_7_days_natal"
      ]
    },
    "period_resolution": { "$ref": "#/definitions/period_resolution" },
    "scan_plan": { "$ref": "#/definitions/scan_plan" },
    "target_language": { "type": "string" },
    "week_overview_plan": {
      "type": "object",
      "required": ["dominant_theme", "tone", "trajectory_hint", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "dominant_theme": { "type": "string" },
        "tone": { "type": "string" },
        "trajectory_hint": { "type": "string" },
        "evidence_keys": { "type": "array", "maxItems": 4, "items": { "type": "string" } }
      }
    },
    "detail_profile_code": { "type": "string" },
    "period_events": { "type": "array", "maxItems": 50, "items": { "$ref": "#/definitions/period_event" } },
    "main_events": { "type": "array", "maxItems": 18, "items": { "$ref": "#/definitions/period_event" } },
    "key_days": { "type": "array", "maxItems": 4, "items": { "$ref": "#/definitions/day_marker" } },
    "best_days": { "type": "array", "maxItems": 3, "items": { "$ref": "#/definitions/day_marker" } },
    "watch_days": { "type": "array", "maxItems": 3, "items": { "$ref": "#/definitions/day_marker" } },
    "watch_summary_plan": { "$ref": "#/definitions/watch_summary" },
    "best_windows": { "type": "array", "maxItems": 3, "items": { "$ref": "#/definitions/best_window" } },
    "watch_windows": { "type": "array", "maxItems": 3, "items": { "$ref": "#/definitions/watch_window" } },
    "strategy": { "$ref": "#/definitions/strategy" },
    "premium_scores": { "type": "object" },
    "editorial_brief": { "$ref": "#/definitions/editorial_brief" },
    "daily_plans": {
      "type": "array",
      "maxItems": 7,
      "items": { "$ref": "#/definitions/daily_plan" }
    },
    "domain_sections": { "type": "array", "maxItems": 5, "items": { "$ref": "#/definitions/domain_section" } },
    "evidence": { "type": "array", "maxItems": 50, "items": { "$ref": "#/definitions/evidence" } }
  },
  "definitions": {
    "period_resolution": {
      "type": "object",
      "required": [
        "period_profile_code",
        "anchor_date",
        "timezone",
        "start_datetime_local",
        "end_datetime_local",
        "start_datetime_utc",
        "end_datetime_utc",
        "end_exclusive",
        "duration_days",
        "included_dates",
        "included_days"
      ],
      "additionalProperties": false,
      "properties": {
        "period_profile_code": { "type": "string" },
        "anchor_date": { "type": "string" },
        "timezone": { "type": "string" },
        "start_datetime_local": { "type": "string" },
        "end_datetime_local": { "type": "string" },
        "start_datetime_utc": { "type": "string" },
        "end_datetime_utc": { "type": "string" },
        "end_exclusive": { "type": "boolean" },
        "duration_days": { "type": "integer" },
        "included_dates": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "included_days": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scan_plan": {
      "type": "object",
      "required": ["scan_profile_code", "granularity", "snapshot_count", "snapshots"],
      "additionalProperties": false,
      "properties": {
        "scan_profile_code": { "type": "string" },
        "granularity": { "type": "string" },
        "snapshot_count": { "type": "integer" },
        "snapshots": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/snapshot" } }
      }
    },
    "snapshot": {
      "type": "object",
      "required": ["snapshot_key", "date", "reference_time_local", "reference_datetime_local", "reference_datetime_utc"],
      "additionalProperties": false,
      "properties": {
        "snapshot_key": { "type": "string" },
        "date": { "type": "string" },
        "reference_time_local": { "type": "string" },
        "reference_datetime_local": { "type": "string" },
        "reference_datetime_utc": { "type": "string" }
      }
    },
    "period_event": {
      "type": "object",
      "required": [
        "event_key",
        "event_type",
        "date",
        "snapshot_key",
        "theme_code",
        "tone",
        "aspect",
        "score",
        "theme_density_score",
        "fact_type",
        "transiting_object",
        "natal_target",
        "natal_house",
        "natal_focus_hint",
        "personalization_hint",
        "evidence_keys"
      ],
      "additionalProperties": false,
      "properties": {
        "event_key": { "type": "string" },
        "event_type": { "type": "string" },
        "date": { "type": "string" },
        "snapshot_key": { "type": ["string", "null"] },
        "theme_code": { "type": "string" },
        "tone": { "type": "string" },
        "aspect": { "type": ["string", "null"] },
        "score": { "type": "number" },
        "theme_density_score": { "type": "number" },
        "fact_type": { "type": ["string", "null"] },
        "transiting_object": { "type": ["string", "null"] },
        "natal_target": { "type": ["string", "null"] },
        "natal_house": { "type": ["integer", "null"] },
        "natal_focus_hint": { "type": ["string", "null"] },
        "personalization_hint": { "type": ["string", "null"] },
        "evidence_keys": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "day_marker": {
      "type": "object",
      "required": ["date", "title", "reason", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "title": { "type": "string" },
        "reason": { "type": "string" },
        "evidence_keys": { "type": "array", "items": { "type": "string" } },
        "fallback_reason": { "type": ["string", "null"] }
      }
    },
    "daily_plan": {
      "type": "object",
      "required": ["date", "day_label", "theme_code", "theme_label", "tone", "summary_hint", "advice_hint", "style_variant_code", "avoid_terms", "natal_focus_hint", "personalization_hint", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "day_label": { "type": "string" },
        "theme_code": { "type": "string" },
        "theme_label": { "type": "string" },
        "tone": { "type": "string" },
        "summary_hint": { "type": "string" },
        "advice_hint": { "type": "string" },
        "style_variant_code": { "type": "string" },
        "avoid_terms": { "type": "array", "items": { "type": "string" } },
        "natal_focus_hint": { "type": "string" },
        "personalization_hint": { "type": "string" },
        "evidence_keys": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "editorial_brief": {
      "type": "object",
      "required": ["purpose", "days"],
      "additionalProperties": false,
      "properties": {
        "purpose": { "type": "string" },
        "days": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "items": { "$ref": "#/definitions/editorial_day" }
        }
      }
    },
    "editorial_day": {
      "type": "object",
      "required": [
        "date",
        "public_role",
        "narrative_function",
        "reader_situation",
        "action_mode",
        "contrast_with_previous_day",
        "avoid_angle_reuse"
      ],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "public_role": { "type": "string" },
        "narrative_function": { "type": "string" },
        "reader_situation": { "type": "string" },
        "action_mode": { "type": "string" },
        "contrast_with_previous_day": { "type": "string" },
        "avoid_angle_reuse": { "type": "string" }
      }
    },
    "domain_section": {
      "type": "object",
      "required": ["domain", "title", "focus", "natal_focus_hint", "personalization_hint", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "domain": { "type": "string" },
        "title": { "type": "string" },
        "focus": { "type": "string" },
        "natal_focus_hint": { "type": "string" },
        "personalization_hint": { "type": "string" },
        "evidence_keys": { "type": "array", "items": { "type": "string" } }
      }
    },
    "watch_summary": {
      "type": "object",
      "required": ["status", "text", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["active", "low", "none"] },
        "text": { "type": "string" },
        "evidence_keys": { "type": "array", "items": { "type": "string" } }
      }
    },
    "best_window": {
      "type": "object",
      "required": ["date", "time_range_label", "source_snapshot_keys", "title", "theme", "tone", "reason", "best_for", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "time_range_label": { "type": "string" },
        "source_snapshot_keys": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "title": { "type": "string" },
        "theme": { "type": "string" },
        "tone": { "type": "string" },
        "reason": { "type": "string" },
        "best_for": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence_keys": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "watch_window": {
      "type": "object",
      "required": ["date", "time_range_label", "source_snapshot_keys", "title", "theme", "tone", "watch_point", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "time_range_label": { "type": "string" },
        "source_snapshot_keys": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "title": { "type": "string" },
        "theme": { "type": "string" },
        "tone": { "type": "string" },
        "watch_point": { "type": "string" },
        "evidence_keys": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "strategy": {
      "type": "object",
      "required": ["title", "focus", "best_use", "recovery", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "focus": { "type": "string" },
        "best_use": { "type": "string" },
        "recovery": { "type": "string" },
        "evidence_keys": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["evidence_key", "date", "fact_type", "source", "theme_code", "human_label", "natal_focus_label", "natal_focus_hint", "personalization_hint"],
      "additionalProperties": true,
      "properties": {
        "evidence_key": { "type": "string" },
        "date": { "type": "string" },
        "fact_type": { "type": "string" },
        "source": { "type": "string" },
        "theme_code": { "type": "string" },
        "human_label": { "type": "string" }
      }
    }
  }
}
