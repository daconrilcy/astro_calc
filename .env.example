# Copier vers .env et ajuster les secrets.
# PostgreSQL (docker compose)
POSTGRES_DB=astral
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Optionnel si le binaire Rust construit l'URL lui-meme :
# DATABASE_URL=postgres://postgres:change-me@localhost:5432/astral

# Calcul natal (obligatoire pour cargo run --features swisseph-engine)
ASTRAL_SUBJECT_LABEL=Test
# Entree stricte 4A (recommandee pour engine + audit alignes) :
ASTRAL_BIRTH_DATE=1990-01-02
ASTRAL_BIRTH_TIME=03:04:05
ASTRAL_BIRTH_TIMEZONE=Europe/Paris
# Repli legacy (timezone defaut UTC si ASTRAL_BIRTH_TIMEZONE absent) :
# ASTRAL_BIRTH_DATETIME_UTC=1990-01-02T02:04:05Z
ASTRAL_LATITUDE_DEG=48.8566
ASTRAL_LONGITUDE_DEG=2.3522
ASTRAL_REFERENCE_VERSION_ID=1
# Cles metier (prioritaires sur les *_ID) — alignees engine et --audit-only :
ASTRAL_ZODIACAL_REFERENCE_SYSTEM=tropical
ASTRAL_COORDINATE_REFERENCE_SYSTEM=geocentric
ASTRAL_HOUSE_SYSTEM=placidus
# Ou IDs numeriques (scripts golden v13) :
# ASTRAL_ZODIACAL_REFERENCE_SYSTEM_ID=1
# ASTRAL_COORDINATE_REFERENCE_SYSTEM_ID=1
# ASTRAL_HOUSE_SYSTEM_ID=1
ASTRAL_PRODUCT_CODE=basic
ASTRAL_EPHEMERIS_PATH=ephe/se-2026a

# Enveloppe 4A (defaut cargo run) :
ASTRAL_PROJECTION_LEVEL=rich
# ASTRAL_OUTPUT_CONTRACT=engine
# ASTRAL_OUTPUT_CONTRACT=audit
# ASTRAL_REQUEST_ID=
# ASTRAL_IDEMPOTENCY_KEY=

# --- astral_llm (gateway LLM, cargo run -p astral_llm_api) ---
ASTRAL_LLM_ENV=local
ASTRAL_LLM_HOST=127.0.0.1
ASTRAL_LLM_PORT=8081
ASTRAL_LLM_API_KEY=
ASTRAL_LLM_PROMPTS_DIR=astral_llm/prompts
ASTRAL_LLM_DEFAULT_PROVIDER=fake
ASTRAL_LLM_DEFAULT_MODEL=fake-model
# Chaine explicite uniquement (pas de priorite OpenAI imposee) :
# ASTRAL_LLM_FALLBACK_PROVIDERS=mistral,anthropic
ASTRAL_LLM_FALLBACK_ENABLED=true
ASTRAL_LLM_ALLOW_CROSS_PROVIDER_FALLBACK=false
ASTRAL_LLM_ENABLE_FAKE=true
ASTRAL_LLM_ENABLE_PERSISTENCE=false
ASTRAL_LLM_DB_AUTO_MIGRATE=true
ASTRAL_LLM_PRODUCTION_MODE=internal
ASTRAL_LLM_STORE_SANITIZED_PAYLOADS=false
ASTRAL_LLM_ALLOW_PUBLIC_BIND=false
ASTRAL_LLM_MAX_BODY_BYTES=2097152
ASTRAL_LLM_MAX_ASTRO_JSON_BYTES=524288
ASTRAL_LLM_MAX_DOMAIN_COUNT=12
ASTRAL_LLM_REQUEST_TIMEOUT_MS=120000
ASTRAL_LLM_MAX_CONCURRENT_REQUESTS=32
ASTRAL_LLM_MAX_CONCURRENT_REQUESTS_PER_KEY=8
ASTRAL_LLM_MAX_REQUESTS_PER_MINUTE_PER_KEY=120
ASTRAL_LLM_MAX_PREMIUM_RUNS_PER_KEY=4
ASTRAL_LLM_CIRCUIT_BREAKER_FAILURES=5
ASTRAL_LLM_CIRCUIT_BREAKER_OPEN_SECS=60
ASTRAL_LLM_IDEMPOTENCY_TTL_HOURS=24

# Logs (stdout + fichier optionnel)
# ASTRAL_LLM_LOG_LEVEL=debug
# ASTRAL_LLM_LOG_FORMAT=json
# ASTRAL_LLM_LOG_FILE=output/logs/astral_llm_api.log
# ASTRAL_LLM_LOG_COMPILED_PROMPTS=true
# ASTRAL_LLM_PROMPT_LOG_DIR=output/logs/prompts

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_DEFAULT_MODEL=gpt-5.4-mini

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai
