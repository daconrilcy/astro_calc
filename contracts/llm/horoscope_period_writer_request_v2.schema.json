{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_period_writer_request_v2",
  "type": "object",
  "required": [
    "contract_version",
    "service_code",
    "generation_mode",
    "target_language_code",
    "period_resolution",
    "scan_plan",
    "detail_profile_code",
    "semantic_brief",
    "evidence",
    "safety_profile",
    "output_contract_version"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "const": "horoscope_period_writer_request_v2" },
    "service_code": {
      "enum": [
        "horoscope_free_next_7_days_natal",
        "horoscope_basic_next_7_days_natal",
        "horoscope_premium_next_7_days_natal"
      ]
    },
    "generation_mode": { "const": "semantic_brief_v2" },
    "target_language_code": { "enum": ["fr", "en", "es", "de"] },
    "astrologer_persona": { "type": ["object", "null"] },
    "period_resolution": { "type": "object" },
    "scan_plan": { "type": "object" },
    "detail_profile_code": { "enum": ["free_compact", "basic_standard", "premium_rich"] },
    "semantic_brief": {
      "type": "object",
      "required": [
        "daily_signal_summary",
        "best_day_candidates",
        "watch_day_candidates",
        "key_day_candidates",
        "window_candidates",
        "domain_candidates",
        "repeating_arcs",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "daily_signal_summary": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": { "$ref": "#/definitions/daily_signal_summary" }
        },
        "best_day_candidates": { "type": "array", "items": { "$ref": "#/definitions/day_candidate" } },
        "watch_day_candidates": { "type": "array", "items": { "$ref": "#/definitions/day_candidate" } },
        "key_day_candidates": { "type": "array", "items": { "$ref": "#/definitions/day_candidate" } },
        "window_candidates": { "type": "array", "items": { "$ref": "#/definitions/window_candidate" } },
        "domain_candidates": { "type": "array", "items": { "$ref": "#/definitions/domain_candidate" } },
        "repeating_arcs": { "type": "array", "items": { "type": "object" } },
        "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/evidence" } }
      }
    },
    "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/evidence" } },
    "safety_profile": { "type": "object" },
    "output_contract_version": { "const": "horoscope_period_response_v1" }
  },
  "definitions": {
    "daily_signal_summary": {
      "type": "object",
      "required": [
        "date",
        "day_index",
        "main_event_keys",
        "evidence_keys",
        "theme_codes",
        "tone_codes",
        "intensity",
        "keywords",
        "opportunity_keywords",
        "risk_keywords",
        "avoid_keywords"
      ],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "day_index": { "type": "integer" },
        "main_event_keys": { "type": "array", "items": { "type": "string" } },
        "evidence_keys": { "type": "array", "items": { "type": "string" } },
        "theme_codes": { "type": "array", "items": { "type": "string" } },
        "tone_codes": { "type": "array", "items": { "type": "string" } },
        "intensity": { "type": "string" },
        "role_hint": { "type": ["string", "null"] },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "opportunity_keywords": { "type": "array", "items": { "type": "string" } },
        "risk_keywords": { "type": "array", "items": { "type": "string" } },
        "avoid_keywords": { "type": "array", "items": { "type": "string" } }
      }
    },
    "day_candidate": {
      "type": "object",
      "required": ["date", "candidate_type", "score", "keywords", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "candidate_type": { "enum": ["key", "best", "watch"] },
        "score": { "type": "number" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "evidence_keys": { "type": "array", "items": { "type": "string" } }
      }
    },
    "window_candidate": {
      "type": "object",
      "required": [
        "date",
        "time_range_label",
        "candidate_type",
        "score",
        "usage_keywords",
        "tone_code",
        "theme_code",
        "evidence_keys",
        "source_snapshot_keys"
      ],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "time_range_label": { "type": "string" },
        "candidate_type": { "enum": ["best", "watch"] },
        "score": { "type": "number" },
        "usage_keywords": { "type": "array", "items": { "type": "string" } },
        "tone_code": { "type": "string" },
        "theme_code": { "type": "string" },
        "evidence_keys": { "type": "array", "items": { "type": "string" } },
        "source_snapshot_keys": { "type": "array", "items": { "type": "string" } }
      }
    },
    "domain_candidate": {
      "type": "object",
      "required": ["domain_code", "weight", "keywords", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "domain_code": { "type": "string" },
        "weight": { "type": "number" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "evidence_keys": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "evidence_key",
        "snapshot_key",
        "date",
        "fact_type",
        "theme_code",
        "tone",
        "keywords"
      ],
      "additionalProperties": false,
      "properties": {
        "evidence_key": { "type": "string" },
        "snapshot_key": { "type": ["string", "null"] },
        "date": { "type": "string" },
        "fact_type": { "type": ["string", "null"] },
        "transiting_object": { "type": ["string", "null"] },
        "aspect": { "type": ["string", "null"] },
        "natal_target": { "type": ["string", "null"] },
        "natal_house": { "type": ["integer", "null"] },
        "theme_code": { "type": "string" },
        "tone": { "type": "string" },
        "score_hint": { "type": ["number", "null"] },
        "keywords": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
