{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_period_response_v1",
  "type": "object",
  "required": [
    "contract_version",
    "service_code",
    "period_resolution",
    "week_overview",
    "key_days",
    "best_days",
    "watch_days",
    "daily_timeline",
    "domain_sections",
    "advice",
    "evidence_summary",
    "quality"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "const": "horoscope_period_response_v1" },
    "service_code": { "const": "horoscope_basic_next_7_days_natal" },
    "period_resolution": { "type": "object" },
    "week_overview": {
      "type": "object",
      "required": ["title", "text", "trajectory"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "text": { "type": "string" },
        "trajectory": { "type": "string" }
      }
    },
    "key_days": { "type": "array", "maxItems": 3, "items": { "$ref": "#/definitions/day_marker" } },
    "best_days": { "type": "array", "maxItems": 2, "items": { "$ref": "#/definitions/day_marker" } },
    "watch_days": { "type": "array", "maxItems": 2, "items": { "$ref": "#/definitions/day_marker" } },
    "daily_timeline": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": { "$ref": "#/definitions/timeline_day" }
    },
    "domain_sections": { "type": "array", "items": { "$ref": "#/definitions/domain_section" } },
    "advice": {
      "type": "object",
      "required": ["main", "best_use", "avoid"],
      "additionalProperties": false,
      "properties": {
        "main": { "type": "string" },
        "best_use": { "type": "string" },
        "avoid": { "type": "string" }
      }
    },
    "evidence_summary": { "type": "array", "items": { "type": "object" } },
    "quality": { "type": "object" }
  },
  "definitions": {
    "day_marker": {
      "type": "object",
      "required": ["date", "title", "reason", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "title": { "type": "string" },
        "reason": { "type": "string" },
        "evidence_keys": { "type": "array", "items": { "type": "string" } },
        "fallback_reason": { "type": "string" }
      }
    },
    "timeline_day": {
      "type": "object",
      "required": ["date", "day_label", "theme", "tone", "text", "advice", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "day_label": { "type": "string" },
        "theme": { "type": "string" },
        "tone": { "type": "string" },
        "text": { "type": "string" },
        "advice": { "type": "string" },
        "evidence_keys": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "domain_section": {
      "type": "object",
      "required": ["domain", "title", "text", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "domain": { "type": "string" },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "evidence_keys": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
