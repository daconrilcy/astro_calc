{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "horoscope_period_interpretation_request_v1",
  "type": "object",
  "required": [
    "contract_version",
    "service_code",
    "period_resolution",
    "scan_plan",
    "target_language",
    "week_overview_plan",
    "period_events",
    "main_events",
    "key_days",
    "best_days",
    "watch_days",
    "daily_plans",
    "domain_sections",
    "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "const": "horoscope_period_interpretation_request_v1" },
    "service_code": { "const": "horoscope_basic_next_7_days_natal" },
    "period_resolution": { "$ref": "#/definitions/period_resolution" },
    "scan_plan": { "$ref": "#/definitions/scan_plan" },
    "target_language": { "type": "string" },
    "week_overview_plan": {
      "type": "object",
      "required": ["dominant_theme", "tone", "trajectory_hint", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "dominant_theme": { "type": "string" },
        "tone": { "type": "string" },
        "trajectory_hint": { "type": "string" },
        "evidence_keys": { "type": "array", "maxItems": 4, "items": { "type": "string" } }
      }
    },
    "period_events": { "type": "array", "maxItems": 8, "items": { "$ref": "#/definitions/period_event" } },
    "main_events": { "type": "array", "maxItems": 8, "items": { "$ref": "#/definitions/period_event" } },
    "key_days": { "type": "array", "maxItems": 3, "items": { "$ref": "#/definitions/day_marker" } },
    "best_days": { "type": "array", "maxItems": 2, "items": { "$ref": "#/definitions/day_marker" } },
    "watch_days": { "type": "array", "maxItems": 2, "items": { "$ref": "#/definitions/day_marker" } },
    "daily_plans": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": { "$ref": "#/definitions/daily_plan" }
    },
    "domain_sections": { "type": "array", "items": { "$ref": "#/definitions/domain_section" } },
    "evidence": { "type": "array", "maxItems": 20, "items": { "$ref": "#/definitions/evidence" } }
  },
  "definitions": {
    "period_resolution": {
      "type": "object",
      "required": [
        "period_profile_code",
        "anchor_date",
        "timezone",
        "start_datetime_local",
        "end_datetime_local",
        "start_datetime_utc",
        "end_datetime_utc",
        "end_exclusive",
        "duration_days",
        "included_dates",
        "included_days"
      ],
      "additionalProperties": false,
      "properties": {
        "period_profile_code": { "type": "string" },
        "anchor_date": { "type": "string" },
        "timezone": { "type": "string" },
        "start_datetime_local": { "type": "string" },
        "end_datetime_local": { "type": "string" },
        "start_datetime_utc": { "type": "string" },
        "end_datetime_utc": { "type": "string" },
        "end_exclusive": { "type": "boolean" },
        "duration_days": { "type": "integer" },
        "included_dates": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "included_days": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scan_plan": {
      "type": "object",
      "required": ["scan_profile_code", "granularity", "snapshot_count", "snapshots"],
      "additionalProperties": false,
      "properties": {
        "scan_profile_code": { "type": "string" },
        "granularity": { "type": "string" },
        "snapshot_count": { "type": "integer" },
        "snapshots": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/snapshot" } }
      }
    },
    "snapshot": {
      "type": "object",
      "required": ["snapshot_key", "date", "reference_time_local", "reference_datetime_local", "reference_datetime_utc"],
      "additionalProperties": false,
      "properties": {
        "snapshot_key": { "type": "string" },
        "date": { "type": "string" },
        "reference_time_local": { "type": "string" },
        "reference_datetime_local": { "type": "string" },
        "reference_datetime_utc": { "type": "string" }
      }
    },
    "period_event": {
      "type": "object",
      "required": ["event_key", "event_type", "date", "theme_code", "tone", "score", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "event_key": { "type": "string" },
        "event_type": { "type": "string" },
        "date": { "type": "string" },
        "theme_code": { "type": "string" },
        "tone": { "type": "string" },
        "score": { "type": "number" },
        "evidence_keys": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "day_marker": {
      "type": "object",
      "required": ["date", "title", "reason", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "title": { "type": "string" },
        "reason": { "type": "string" },
        "evidence_keys": { "type": "array", "items": { "type": "string" } },
        "fallback_reason": { "type": "string" }
      }
    },
    "daily_plan": {
      "type": "object",
      "required": ["date", "day_label", "theme_code", "tone", "summary_hint", "advice_hint", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string" },
        "day_label": { "type": "string" },
        "theme_code": { "type": "string" },
        "tone": { "type": "string" },
        "summary_hint": { "type": "string" },
        "advice_hint": { "type": "string" },
        "evidence_keys": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "domain_section": {
      "type": "object",
      "required": ["domain", "title", "focus", "evidence_keys"],
      "additionalProperties": false,
      "properties": {
        "domain": { "type": "string" },
        "title": { "type": "string" },
        "focus": { "type": "string" },
        "evidence_keys": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["evidence_key", "date", "fact_type", "source", "theme_code", "human_label"],
      "additionalProperties": true,
      "properties": {
        "evidence_key": { "type": "string" },
        "date": { "type": "string" },
        "fact_type": { "type": "string" },
        "source": { "type": "string" },
        "theme_code": { "type": "string" },
        "human_label": { "type": "string" }
      }
    }
  }
}
