{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astral-calculation.local/schemas/natal_simplified_structured_v1.schema.json",
  "title": "Natal Simplified Structured v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "payload_contract",
    "computed_scope",
    "input_precision_level",
    "facts",
    "ambiguous_facts",
    "excluded_features",
    "planets"
  ],
  "properties": {
    "payload_contract": { "const": "natal_simplified_structured_v1" },
    "computed_scope": {
      "type": "string",
      "enum": [
        "stable_birth_date_profile",
        "planetary_positions",
        "angular_chart"
      ]
    },
    "input_precision_level": { "type": "string" },
    "facts": {
      "type": "array",
      "items": { "$ref": "#/$defs/sign_fact" }
    },
    "ambiguous_facts": {
      "type": "array",
      "items": { "$ref": "#/$defs/ambiguous_sign_fact" }
    },
    "excluded_features": {
      "type": "array",
      "items": { "type": "string" }
    },
    "planets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sign"],
        "properties": {
          "sign": { "type": "string" }
        }
      }
    },
    "position_count": { "type": "integer", "minimum": 0 },
    "house_cusp_count": { "type": "integer", "minimum": 0 },
    "aspect_count": { "type": "integer", "minimum": 0 },
    "llm_controls": { "type": "object" }
  },
  "$defs": {
    "sign_fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_code", "fact_type", "sign_code", "reliability"],
      "properties": {
        "object_code": { "type": "string" },
        "fact_type": { "const": "sign" },
        "sign_code": { "type": "string" },
        "reliability": { "type": "string" },
        "longitude_deg": { "type": ["number", "null"] }
      }
    },
    "ambiguous_sign_fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_code", "fact_type", "possible_sign_codes", "reliability"],
      "properties": {
        "object_code": { "type": "string" },
        "fact_type": { "const": "sign" },
        "possible_sign_codes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "reliability": { "const": "ambiguous_across_uncertainty_window" }
      }
    }
  }
}
